PORT=3001
# Set this same value in Meta Dashboard -> WhatsApp -> Configuration -> Verify token
WHATSAPP_VERIFY_TOKEN=replace-with-random-string

# Meta App Secret (used to verify X-Hub-Signature-256). Recommended for production.
# You can also use META_APP_SECRET instead of WHATSAPP_APP_SECRET.
WHATSAPP_APP_SECRET=replace-with-meta-app-secret

# Optional (only needed if you use /api/whatsapp/send)
WHATSAPP_ACCESS_TOKEN=replace-with-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id

# Optional initiation template config.
# Examples:
# WHATSAPP_INIT_TEMPLATE_NAME=your_template_name
# WHATSAPP_INIT_TEMPLATE_LANG=en_US
# WHATSAPP_INIT_TEMPLATE_PARAM_ORDER=none
# WHATSAPP_INIT_TEMPLATE_PARAM_ORDER=contactName
# WHATSAPP_INIT_TEMPLATE_PARAM_ORDER=contactName,agentName
# WHATSAPP_INIT_TEMPLATE_PREVIEW_TEXT=Hello 👋,\n\nThis is UniSolvex team. We would like to start a conversation with you.\n\nPlease reply to this message so we can talk.\n\nThank you!
WHATSAPP_INIT_TEMPLATE_NAME=
WHATSAPP_INIT_TEMPLATE_LANG=en_US
WHATSAPP_EXPERT_NOTIFY_TEMPLATE_NAME=
WHATSAPP_EXPERT_NOTIFY_TEMPLATE_LANG=en_US
# Example order:
# WHATSAPP_EXPERT_NOTIFY_TEMPLATE_PARAM_ORDER=expertName,taskTitle,serviceType,expertDeadline,expertPayout
WHATSAPP_EXPERT_NOTIFY_TEMPLATE_PARAM_ORDER=
WHATSAPP_EXPERT_NOTIFY_TEMPLATE_PREVIEW_TEXT=Hello {{expertName}},\n\nA new task is available from UniSolvex.\nTask: {{taskTitle}}\nService: {{serviceType}}\nExpert deadline: {{expertDeadline}}\nExpert payout: {{expertPayout}}\n\nPlease reply if you are available.

# Optional persistent chat storage (recommended for production)
# Render can store this as raw JSON or base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_STORAGE_BUCKET=
WHATSAPP_MEDIA_STORAGE_PREFIX=whatsapp-media

# Firebase Authentication web app config for the CRM login page
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_STORAGE_BUCKET=

# Comma-separated allowlists for CRM access
FIREBASE_AUTH_ADMIN_EMAILS=
FIREBASE_AUTH_AGENT_EMAILS=

# Optional AI agent testing override: comma-separated WhatsApp IDs/numbers
# that should keep AI active even after human handoff or pricing/max-reply rules.
AI_AGENT_ALWAYS_ACTIVE_WA_IDS=
AI_AGENT_TONE_GUIDE=Professional, polished, concise, respectful, confident, and clear.
AI_AGENT_LANGUAGE_POLICY=Reply in the client's language whenever possible. If the client writes in Hindi, reply in professional Hinglish. If the client writes in English, reply in English. If the client mixes Hindi and English, reply naturally in professional Hinglish. If the language is unclear, use simple professional English.
