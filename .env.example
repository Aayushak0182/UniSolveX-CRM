PORT=3001
# Set this same value in Meta Dashboard -> WhatsApp -> Configuration -> Verify token
WHATSAPP_VERIFY_TOKEN=replace-with-random-string

# Meta App Secret (used to verify X-Hub-Signature-256). Recommended for production.
# You can also use META_APP_SECRET instead of WHATSAPP_APP_SECRET.
WHATSAPP_APP_SECRET=replace-with-meta-app-secret

# Optional (only needed if you use /api/whatsapp/send)
WHATSAPP_ACCESS_TOKEN=replace-with-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
